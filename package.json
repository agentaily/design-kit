{
  "name": "@agentaily/design-kit",
  "version": "0.0.0",
  "description": "Claude-Design-only browser mock backend — patch window.fetch + Tweaks-driven scenarios for high-fidelity SPA prototypes (CDN-imported into Claude Design).",
  "type": "module",
  "license": "MIT",
  "author": "agentaily",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentaily/design-kit.git"
  },
  "homepage": "https://github.com/agentaily/design-kit#readme",
  "bugs": {
    "url": "https://github.com/agentaily/design-kit/issues"
  },
  "keywords": [
    "mock",
    "fetch",
    "claude-design",
    "prototype",
    "tweaks",
    "high-fidelity",
    "agentaily"
  ],
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "release": "changeset publish",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.11",
    "jsdom": "^25.0.1",
    "lefthook": "^1.10.1",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
